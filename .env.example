# Environment template — copy to `.env` and fill locally. Never commit `.env`.

# --- Site ---
SITE_NAME=Home
SITE_TIMEZONE=America/Chicago

# --- PVS6 (LAN only) ---
# Router-assigned Wi-Fi address of YOUR PVS6. Do not scan other hosts.
PVS_HOST=192.168.1.96
PVS_PORT=443
# Use https with certificate verification disabled only if the PVS presents a self-signed cert
# and you understand the LAN trust model. Prefer documenting the observed cert fingerprint later.
PVS_SCHEME=https
PVS_VERIFY_TLS=false

# Owner auth (SunStrong documented local API, firmware >= 61840).
# Username is typically ssm_owner. Password is the last 5 characters of YOUR PVS serial.
# Never commit real values.
PVS_USERNAME=ssm_owner
PVS_PASSWORD=

# fixture = replay redacted fixtures (safe default, no PVS contact)
# varserver = live read-only polls of your PVS
COLLECTOR_SOURCE=fixture

# Collection safety
PVS_POLL_INTERVAL_SECONDS=300
PVS_REQUEST_TIMEOUT_SECONDS=30
PVS_MAX_CONCURRENCY=1
PVS_CIRCUIT_BREAKER_FAILURES=3
PVS_CIRCUIT_BREAKER_RESET_SECONDS=900

# --- Database ---
POSTGRES_USER=solar
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=solar_monitor
DATABASE_URL=postgresql://solar:change-me-locally@db:5432/solar_monitor

# --- API / Web ---
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3080
# LAN / Tailscale / phone auth token for web + Android (generate a long random string locally)
# Example: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_AUTH_TOKEN=
CORS_ORIGINS=*

# --- Cloud sync (home → DigitalOcean read replica) ---
# Enable with: docker compose --profile cloud-sync up -d cloud-sync
CLOUD_SYNC_URL=https://solar.blackmagicsoftware.net
# Must match CLOUD_SYNC_TOKEN on the droplet (ingest auth). Not the phone API_AUTH_TOKEN.
CLOUD_SYNC_TOKEN=
CLOUD_SYNC_INTERVAL_SECONDS=300
CLOUD_SYNC_HISTORY_HOURS=48

# --- Retention ---
RAW_PAYLOAD_RETENTION_DAYS=7
MEASUREMENT_RETENTION_DAYS=1825

# --- Logging ---
LOG_LEVEL=INFO
LOG_REDACT=true
