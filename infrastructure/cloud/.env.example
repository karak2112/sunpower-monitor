# Cloud droplet env template — copy to /opt/solar-cloud/.env on the droplet.
# Never commit real secrets.

POSTGRES_USER=solar
POSTGRES_PASSWORD=change-me-db
POSTGRES_DB=solar_monitor_cloud
DATABASE_URL=postgresql://solar:change-me-db@db:5432/solar_monitor_cloud

# Phone / Android Bearer token
API_AUTH_TOKEN=change-me-phone-token

# Home syncer Bearer / X-Sync-Token (different from phone token)
CLOUD_SYNC_TOKEN=change-me-sync-token

API_HOST=solar.blackmagicsoftware.net
ACME_EMAIL=you@example.com
CORS_ORIGINS=*
